rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'rakhmadi.rahman90@gmail.com'
      );
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }

    // Courts
    match /courts/{courtId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Time Slots
    match /timeSlots/{slotId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Bookings
    match /bookings/{bookingId} {
      allow read: if true; 
      allow create: if true; // Allow guests to book
      allow update, delete: if isAdmin();
    }

    // Contacts
    match /contacts/{contactId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Settings - Specifically allow anyone to read hero settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admins
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && !exists(/databases/$(database)/documents/admins));
    }

    // Test connection doc
    match /test/connection {
      allow read: if true;
    }
  }
}
